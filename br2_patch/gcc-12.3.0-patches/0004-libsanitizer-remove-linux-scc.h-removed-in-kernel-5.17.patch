From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Buildroot <buildroot@buildroot.org>
Date: Mon, 04 May 2026 00:00:00 +0000
Subject: [PATCH] libsanitizer: remove linux/scc.h include removed in kernel 5.17

linux/scc.h was removed from the kernel headers in v5.17 when the
Z8530 SCC driver was removed. GCC 12's libsanitizer still references
it, causing build failures with kernel headers >= 5.17.

Remove the include and the two struct size entries that depend on it.
Upstream fix landed in GCC 13.

Signed-off-by: Buildroot <buildroot@buildroot.org>
---
 libsanitizer/sanitizer_common/sanitizer_platform_limits_posix.cpp | 3 ---
 1 file changed, 3 deletions(-)

diff --git a/libsanitizer/sanitizer_common/sanitizer_platform_limits_posix.cpp b/libsanitizer/sanitizer_common/sanitizer_platform_limits_posix.cpp
--- a/libsanitizer/sanitizer_common/sanitizer_platform_limits_posix.cpp
+++ b/libsanitizer/sanitizer_common/sanitizer_platform_limits_posix.cpp
@@ -150,7 +150,6 @@
 #include <linux/lp.h>
 #include <linux/mroute.h>
 #include <linux/mroute6.h>
-#include <linux/scc.h>
 #include <linux/serial.h>
 #include <sys/msg.h>
 #include <sys/ipc.h>
@@ -478,8 +477,6 @@
   unsigned struct_kbsentry_sz = sizeof(struct kbsentry);
   unsigned struct_mtconfiginfo_sz = sizeof(struct mtconfiginfo);
   unsigned struct_nr_parms_struct_sz = sizeof(struct nr_parms_struct);
-  unsigned struct_scc_modem_sz = sizeof(struct scc_modem);
-  unsigned struct_scc_stat_sz = sizeof(struct scc_stat);
   unsigned struct_serial_multiport_struct_sz
       = sizeof(struct serial_multiport_struct);
   unsigned struct_serial_struct_sz = sizeof(struct serial_struct);
